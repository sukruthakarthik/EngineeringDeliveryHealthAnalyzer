# JIRA Configuration
# Replace these values with your actual JIRA credentials
# NEVER commit this file with real credentials - use backend/.env instead

JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# CORS Origins (comma-separated URLs that can access the API)
# Development: localhost URLs are included by default
# Production: Add your production frontend URL
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://your-server.com:8443
